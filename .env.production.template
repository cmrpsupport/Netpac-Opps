# Production on Render - environment template
# Set these in Render dashboard (Environment). Do NOT commit real values to git.

NODE_ENV=production

# SQLite Cloud (required in production). Set to your SQLite Cloud connection URL.
# Format: sqlitecloud://HOST:PORT/DATABASE?apikey=YOUR_API_KEY
# SQLITECLOUD_URL=sqlitecloud://xxx.g4.sqlite.cloud:8860/auth.sqlitecloud?apikey=...

# JWT secret - generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-secure-jwt-secret-here

# Render sets PORT automatically - do not set PORT or HOST

# Frontend URL for CORS (your production frontend URL)
FRONTEND_URL=https://your-frontend-url.onrender.com

# Optional: API base URL (backend URL) - for any server-side config
# API_BASE_URL=https://your-backend.onrender.com
