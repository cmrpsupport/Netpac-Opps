# Database: local SQLite only (cloud DB is not used)
# Create DB first: node scripts/init-local-sqlite.js
USE_SQLITE_LOCAL=1
# Optional: custom path (default: ./data/local.db)
# SQLITE_DB_PATH=./data/local.db

# Net Pacific only: tenant code for login/signup (default = default)
# NETPACIFIC_TENANT_CODE=default

# Project code prefix: set once to align with your company (default = CMRP). Format: PREFIX + YYMM + 4-digit sequence (e.g. NETPAC25020001).
# PROJECT_CODE_PREFIX=CMRP

# JWT Configuration
JWT_SECRET=your_jwt_secret_here

# Environment
NODE_ENV=development
# Bind address: 0.0.0.0 = all IPs (LAN access), 127.0.0.1 = local only
HOST=0.0.0.0
PORT=3000
