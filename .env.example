# Database: SQLite Cloud (recommended). Set this to your SQLite Cloud URL.
# Format: sqlitecloud://HOST:PORT/DATABASE?apikey=YOUR_API_KEY
# Get the URL from your SQLite Cloud dashboard. Never commit the real URL/key to git.
# SQLITECLOUD_URL=sqlitecloud://xxx.g4.sqlite.cloud:8860/auth.sqlitecloud?apikey=...

# Optional: local SQLite only (dev). Uncomment and run: node scripts/init-local-sqlite.js
# USE_SQLITE_LOCAL=1
# SQLITE_DB_PATH=./data/local.db

# Net Pacific only: tenant code for login/signup (default = default)
# NETPACIFIC_TENANT_CODE=default

# Project code prefix (default = CMRP). Format: PREFIX + YYMM + 4-digit sequence.
# PROJECT_CODE_PREFIX=CMRP

# JWT Configuration
JWT_SECRET=your_jwt_secret_here

# Environment
NODE_ENV=development
# Bind address: 0.0.0.0 = all IPs (LAN access), 127.0.0.1 = local only
HOST=0.0.0.0
PORT=3000
