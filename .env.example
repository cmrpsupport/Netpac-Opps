# Google Drive Configuration
GOOGLE_DRIVE_ROOT_FOLDER_ID=your_shared_folder_id_here
GOOGLE_DRIVE_TEMPLATE_FOLDER_ID=your_template_folder_id_here
GOOGLE_DRIVE_AUTO_SHARE=true

# Database
# Local SQLite (create DB first: npm run db:init)
USE_SQLITE_LOCAL=1
# Optional: custom path (default: ./data/local.db)
# SQLITE_DB_PATH=./data/local.db
# Or use PostgreSQL / SQLiteCloud:
# DATABASE_URL=postgres://... or sqlitecloud://...

# JWT Configuration
JWT_SECRET=your_jwt_secret_here

# Environment
NODE_ENV=development
PORT=3000
